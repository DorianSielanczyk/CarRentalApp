@page "/"
@rendermode InteractiveServer
@inject ICarService CarService
@inject ICategoryService CategoryService
@inject IRentalService RentalService
@inject IDialogService DialogService
@inject NavigationManager Navigation

<div class="filter-header">
    <div class="container">
        <div class="row g-2 align-items-center">
            <div class="col-md-3">
                <input type="text" class="form-control" placeholder="Search by brand or model..." @bind="searchQuery" @bind:event="oninput" @bind:after="OnSearchChanged" />
            </div>
            <div class="col-md-3">
                <select class="form-select" @bind="selectedCategoryId" @bind:after="OnFilterChanged">
                    <option value="0">All Categories</option>
                    @if (categories != null)
                    {
                        @foreach (var category in categories)
                        {
                            <option value="@category.Id">@category.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-2">
                <select class="form-select" @bind="selectedPriceRange" @bind:after="OnFilterChanged">
                    <option value="all">Any Price</option>
                    <option value="0-50">Under $50/day</option>
                    <option value="50-100">$50 - $100/day</option>
                    <option value="100-150">$100 - $150/day</option>
                    <option value="150+">Over $150/day</option>
                </select>
            </div>
            <div class="col-md-2">
                <button class="btn btn-outline-filter-date btn-sm w-100 home-date-filter-btn" @onclick="OpenDateRangeDialogAsync">
                    <i class="bi bi-calendar-range"></i> Select Date
                </button>
            </div>
            <div class="col-md-2">
                <button class="btn btn-outline-secondary btn-sm w-100 home-clear-filter-btn" @onclick="ClearFilters">
                    <i class="bi bi-x-circle"></i> Clear Filters
                </button>
            </div>
        </div>

        @if (selectedStartDate.HasValue && selectedEndDate.HasValue)
        {
            <div class="row mt-2">
                <div class="col-12">
                    <small class="text-muted">
                        Availability range:
                        <strong>@selectedStartDate.Value.ToString("dd.MM.yyyy")</strong>
                        -
                        <strong>@selectedEndDate.Value.ToString("dd.MM.yyyy")</strong>
                    </small>
                </div>
            </div>
        }
    </div>
</div>

<div class="container my-4">
    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3 text-muted">Loading our amazing fleet...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <strong>Oops!</strong> @errorMessage
            <button class="btn btn-sm btn-outline-danger ms-3" @onclick="LoadData">Try Again</button>
        </div>
    }
    else if (filteredCars == null || filteredCars.Count == 0)
    {
        <div class="text-center py-5">
            <i class="bi bi-search" style="font-size: 4rem; color: #ccc;"></i>
            <h4 class="mt-3">No cars found</h4>
            <p class="text-muted">Try adjusting your filters.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 row-cols-xl-5 g-4">
            @foreach (var car in PagedCars)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm car-card">
                        <div class="position-relative">
                            @if (!string.IsNullOrEmpty(car.MainPhotoUrl))
                            {
                                <img src="@car.MainPhotoUrl" class="card-img-top car-image" alt="@car.Brand @car.Model" />
                            }
                            else
                            {
                                <div class="card-img-top car-image bg-light d-flex align-items-center justify-content-center">
                                    <i class="bi bi-car-front-fill text-secondary" style="font-size: 3rem;"></i>
                                </div>
                            }

                            @if (car.Status == "Available")
                            {
                                <span class="badge bg-success position-absolute top-0 end-0 m-2">
                                    <i class="bi bi-check-circle-fill"></i> Available
                                </span>
                            }
                            else if (car.Status == "Rented")
                            {
                                <span class="badge bg-danger position-absolute top-0 end-0 m-2">
                                    <i class="bi bi-x-circle-fill"></i> Rented
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary position-absolute top-0 end-0 m-2">
                                    <i class="bi bi-dash-circle-fill"></i> Unavailable
                                </span>
                            }

                            <span class="badge bg-primary position-absolute bottom-0 start-0 m-2">
                                @car.CategoryName
                            </span>
                        </div>

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-bold mb-2">@car.Brand @car.Model</h5>

                            <div class="mb-3 small text-muted">
                                <div class="d-flex justify-content-between mb-1">
                                    <span><i class="bi bi-calendar3"></i> @car.YearOfProduction</span>
                                    <span><i class="bi bi-speedometer2"></i> @car.Mileage.ToString("N0") km</span>
                                </div>
                                <div>
                                    <span><i class="bi bi-card-text"></i> @car.RegistrationNumber</span>
                                </div>
                            </div>

                            <div class="price-section mb-3">
                                <h4 class="text-primary mb-0 fw-bold">
                                    $@car.PricePerDay.ToString("N2")
                                    <small class="text-muted fs-6 fw-normal">/ day</small>
                                </h4>
                            </div>

                            <div class="mt-auto d-grid gap-2">
                                <button class="btn btn-outline-primary btn-sm" @onclick="() => ViewCarDetails(car.Id)">
                                    <i class="bi bi-info-circle"></i> Details
                                </button>
                                <button class="btn btn-primary btn-sm"
                                        @onclick="() => BookCar(car.Id)"
                                        disabled="@(car.Status == "Unavailable")">
                                    <i class="bi bi-calendar-check"></i>
                                    @(car.Status == "Available" ? "Book now" : car.Status == "Rented" ? "Check availability" : "Unavailable")
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="d-flex flex-column align-center">
            <MudPagination ShowFirstButton="true"
                           ShowLastButton="true"
                           Count="@TotalPages"
                           Class="mt-4 home-pagination"
                           @bind-Selected="currentPage" />
        </div>
    }
</div>

@code {
    private List<CarDto> allCars = new List<CarDto>();
    private List<CarDto> filteredCars = new List<CarDto>();
    private List<CategoryDto>? categories;
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private string searchQuery = string.Empty;
    private int selectedCategoryId = 0;
    private string selectedPriceRange = "all";

    private const int PageSize = 10;
    private int currentPage = 1;

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(filteredCars.Count / (double)PageSize));

    private List<CarDto> PagedCars => filteredCars
        .Skip((currentPage - 1) * PageSize)
        .Take(PageSize)
        .ToList();

    private DateTime? selectedStartDate;
    private DateTime? selectedEndDate;
    private HashSet<int> unavailableCarIdsInRange = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            var carsResult = await CarService.GetAllCarsAsync();
            allCars = carsResult?.ToList() ?? new List<CarDto>();

            var categoriesResult = await CategoryService.GetAllCategoriesAsync();
            categories = categoriesResult?.ToList() ?? new List<CategoryDto>();

            await RefreshAvailabilityForSelectedRangeAsync();
            ApplyFilters();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load data: {ex.Message}";
            allCars = new List<CarDto>();
            filteredCars = new List<CarDto>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OnSearchChanged()
    {
        if (!isLoading && allCars != null)
        {
            currentPage = 1;
            ApplyFilters();
        }
    }

    private void OnFilterChanged()
    {
        if (!isLoading && allCars != null)
        {
            currentPage = 1;
            ApplyFilters();
        }
    }

    private void ApplyFilters()
    {
        if (allCars == null || allCars.Count == 0)
        {
            filteredCars = new List<CarDto>();
            currentPage = 1;
            return;
        }

        IEnumerable<CarDto> query = allCars;

        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            query = query.Where(car =>
                (car.Brand?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (car.Model?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false));
        }

        if (selectedCategoryId != 0)
        {
            query = query.Where(car => car.CategoryId == selectedCategoryId);
        }

        switch (selectedPriceRange)
        {
            case "0-50":
                query = query.Where(car => car.PricePerDay < 50);
                break;
            case "50-100":
                query = query.Where(car => car.PricePerDay >= 50 && car.PricePerDay <= 100);
                break;
            case "100-150":
                query = query.Where(car => car.PricePerDay > 100 && car.PricePerDay <= 150);
                break;
            case "150+":
                query = query.Where(car => car.PricePerDay > 150);
                break;
        }

        if (selectedStartDate.HasValue && selectedEndDate.HasValue)
        {
            query = query.Where(car => car.IsAvailable && !unavailableCarIdsInRange.Contains(car.Id));
        }

        filteredCars = query.ToList();

        if (currentPage > TotalPages)
        {
            currentPage = TotalPages;
        }
    }

    private void ClearFilters()
    {
        searchQuery = string.Empty;
        selectedCategoryId = 0;
        selectedPriceRange = "all";
        selectedStartDate = null;
        selectedEndDate = null;
        unavailableCarIdsInRange.Clear();
        currentPage = 1;
        ApplyFilters();
    }

    private void ViewCarDetails(int carId)
    {
        Navigation.NavigateTo($"/car/{carId}");
    }

    private void BookCar(int carId)
    {
        var car = allCars.FirstOrDefault(c => c.Id == carId);
        if (car is null || car.Status == "Unavailable")
        {
            return;
        }

        Navigation.NavigateTo($"/booking/{carId}");
    }

    private async Task OpenDateRangeDialogAsync()
    {
        try
        {
            var parameters = new DialogParameters
            {
                ["StartDate"] = selectedStartDate,
                ["EndDate"] = selectedEndDate
            };

            var options = new DialogOptions
            {
                CloseOnEscapeKey = true,
                CloseButton = false,
                FullWidth = true,
                MaxWidth = MaxWidth.Small,
                Position = DialogPosition.Center
            };

            var dialog = await DialogService.ShowAsync<HomeDateRangeDialog>("Select Date", parameters, options);
            var result = await dialog.Result;

            if (result.Canceled)
            {
                return;
            }

            if (result.Data is DateRange range)
            {
                selectedStartDate = range.Start;
                selectedEndDate = range.End;

                await RefreshAvailabilityForSelectedRangeAsync();
                currentPage = 1;
                ApplyFilters();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Date dialog failed to open: {ex.Message}";
        }
    }

    private async Task RefreshAvailabilityForSelectedRangeAsync()
    {
        unavailableCarIdsInRange.Clear();

        if (!selectedStartDate.HasValue || !selectedEndDate.HasValue)
        {
            return;
        }

        var start = selectedStartDate.Value.Date;
        var end = selectedEndDate.Value.Date;

        var activeRentals = await RentalService.GetActiveRentalsAsync();

        unavailableCarIdsInRange = activeRentals
            .Where(r =>
                r.Status != "Cancelled" &&
                r.RentalDate.Date <= end &&
                r.ReturnDate.Date >= start)
            .Select(r => r.CarId)
            .ToHashSet();
    }
}