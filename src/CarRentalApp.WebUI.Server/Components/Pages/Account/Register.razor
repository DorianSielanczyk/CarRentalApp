@page "/register"
@rendermode InteractiveServer
@inject UserManager<IdentityUser> UserManager
@inject IClientService ClientService
@inject NavigationManager Navigation
@inject IDialogService DialogService


<div class="register-header">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center">
            <h3 class="mb-0">Register</h3>
        </div>
    </div>
</div>

<div class="register-info">
    <div class="container my-4">
        <div class="register-form-card">
            <EditForm Model="Input" FormName="register" OnValidSubmit="RegisterUser">
                <DataAnnotationsValidator />

                <div class="first-name">
                    <label>First Name:</label>
                    <InputText @bind-Value="Input.FirstName" class="form-control" />
                    <ValidationMessage For="@(() => Input.FirstName)" />
                </div>

                <div class="last-name">
                    <label>Last Name:</label>
                    <InputText @bind-Value="Input.LastName" class="form-control" />
                    <ValidationMessage For="@(() => Input.LastName)" />
                </div>

                <div class="driver-license">
                    <label>Driver License:</label>
                    <InputText @bind-Value="Input.DriverLicense" class="form-control" />
                    <ValidationMessage For="@(() => Input.DriverLicense)" />
                </div>

                <div class="email">
                    <label>E-mail:</label>
                    <InputText @bind-Value="Input.Email" class="form-control" />
                    <ValidationMessage For="@(() => Input.Email)" />
                </div>

                <div class="password">
                    <label>Password:</label>
                    <InputText @bind-Value="Input.Password" type="password" class="form-control" />
                    <ValidationMessage For="@(() => Input.Password)" />
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger">@errorMessage</div>
                }

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary">Register</button>
                    <a href="/login" class="btn btn-outline-secondary">
                        Back to login
                    </a>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    private string? errorMessage;

    private async Task RegisterUser()
    {
        errorMessage = null;

        var user = new IdentityUser
        {
            UserName = Input.Email,
            Email = Input.Email
        };

        var userCreated = false;
        var registrationSucceeded = false;

        try
        {
            var createResult = await UserManager.CreateAsync(user, Input.Password);
            if (!createResult.Succeeded)
            {
                var primaryCreateError =
                    createResult.Errors.FirstOrDefault(e => e.Code == "DuplicateEmail")
                    ?? createResult.Errors.FirstOrDefault(e => e.Code == "DuplicateUserName")
                    ?? createResult.Errors.FirstOrDefault();

                errorMessage = primaryCreateError?.Description ?? "Registration failed.";
                return;
            }

            userCreated = true;

            var roleResult = await UserManager.AddToRoleAsync(user, "User");
            if (!roleResult.Succeeded)
            {
                await UserManager.DeleteAsync(user);

                var roleError = roleResult.Errors.FirstOrDefault();
                errorMessage = roleError?.Description ?? "Failed to assign user role.";
                return;
            }

            var created = await ClientService.CreateClientAsync(new ClientDto
            {
                FirstName = Input.FirstName,
                LastName = Input.LastName,
                DriverLicense = Input.DriverLicense,
                UserId = user.Id
            });

            if (!created)
            {
                await UserManager.DeleteAsync(user);
                errorMessage = "Client profile creation failed.";
                return;
            }

            registrationSucceeded = true;
        }
        catch
        {
            if (userCreated)
            {
                await UserManager.DeleteAsync(user);
            }

            errorMessage = "Registration failed due to an unexpected error.";
            return;
        }

        if (registrationSucceeded)
        {
            var parameters = new DialogParameters
            {
                ["Email"] = Input.Email
            };

            var options = new DialogOptions
            {
                FullWidth = true,
                MaxWidth = MaxWidth.Small,
                CloseOnEscapeKey = true
            };

            var dialogReference = await DialogService.ShowAsync<RegisterSuccessDialog>(
                "Registration successful",
                parameters,
                options);

            var dialogResult = await dialogReference.Result;

            if (!dialogResult.Canceled)
            {
                Navigation.NavigateTo("/login");
            }
        }
    }

    private sealed class InputModel
    {
        [Required]
        public string FirstName { get; set; } = "";

        [Required]
        public string LastName { get; set; } = "";

        [Required]
        [Length(10, 10)]
        public string DriverLicense { get; set; } = "";

        [Required]
        [EmailAddress]
        public string Email { get; set; } = "";

        [Required]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";
    }
}