@page "/booking/{carId:int}"
@rendermode InteractiveServer
@inject    ICarService CarService
@inject IRentalService RentalService
@inject IClientService ClientService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IDialogService DialogService

@if (isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-3 text-muted">Loading car details...</p>
    </div>
}
else if (car is not null)
{
    <div class="car-header">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center">
                <h3 class="mb-0">Book @car.Brand @car.Model</h3>
                <button class="btn btn-outline-secondary back-button" @onclick="Homepage">
                    <i class="bi bi-arrow-left"></i> Back to homepage
                </button>
            </div>
        </div>
    </div>

    <div class="container my-4">
        <div class="row">
            <div class="col-md-4">
                <div class="position-relative">
                    @if (allPhotos.Count > 0)
                    {
                        <img src="@allPhotos[currentPhotoIndex]" class="car-detail-image" alt="@car.Brand @car.Model" />

                        @if (allPhotos.Count > 1)
                        {
                            <button class="btn btn-dark photo-nav-btn photo-nav-prev" @onclick="PreviousPhoto">
                                <i class="bi bi-chevron-left"></i>
                            </button>
                            <button class="btn btn-dark photo-nav-btn photo-nav-next" @onclick="NextPhoto">
                                <i class="bi bi-chevron-right"></i>
                            </button>

                            <div class="photo-indicator">
                                @(currentPhotoIndex + 1) / @allPhotos.Count
                            </div>
                        }
                    }
                    else
                    {
                        <div class="car-detail-image bg-light d-flex align-items-center justify-content-center">
                            <i class="bi bi-car-front-fill text-secondary" style="font-size: 4rem;"></i>
                        </div>
                    }
                </div>

                <div class="price-booking-section mt-3">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <h4 class="text-primary mb-0 fw-bold">
                                @if (totalDays > 0)
                                {
                                    <text>$@totalPrice.ToString("N2")</text>
                                    <small class="text-muted fs-6 fw-normal"> for @totalDays day(s)</small>
                                }
                                else
                                {
                                    <text>$@car.PricePerDay.ToString("N2")</text>
                                    <small class="text-muted fs-6 fw-normal"> / day</small>
                                }
                            </h4>
                        </div>
                    </div>

                    @if (!car.IsAvailable)
                    {
                        <div class="alert alert-secondary mb-3">
                            <i class="bi bi-dash-circle-fill"></i> This car is currently unavailable.
                        </div>
                    }

                    <button class="btn btn-primary w-100"
                            @onclick="ConfirmBooking"
                            disabled="@(totalDays == 0 || !car.IsAvailable)">
                        <i class="bi bi-calendar-check"></i>
                        <text> @(!car.IsAvailable ? "Unavailable" : totalDays > 0 ? "Confirm Booking" : "Select Dates")</text>
                    </button>
                </div>
            </div>

            <div class="col-md-8">
                <div class="calendar-container mx-auto">
                    <MudDateRangePicker PickerVariant="PickerVariant.Static"
                                        DateRange="@_dateRange"
                                        DateRangeChanged="@OnDateRangeChanged"
                                        IsDateDisabledFunc="@IsDateDisabled"
                                        Elevation="2"
                                        MinDate="@DateTime.Today"
                                        AutoClose="false"
                                        FixedDay="@DateTime.Today"
                                        Culture="@(new System.Globalization.CultureInfo("en-US"))" />
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int CarId { get; set; }

    private bool isLoading = true;
    private CarDto? car;
    private List<string> allPhotos = new();
    private int currentPhotoIndex = 0;
    private DateRange? _dateRange { get; set; }
    private List<RentalDto> existingRentals = new();
    private int totalDays = 0;
    private decimal totalPrice = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadCar();
        await LoadExistingRentals();
    }

    private async Task LoadCar()
    {
        isLoading = true;

        try
        {
            car = await CarService.GetCarByIdAsync(CarId);

            if (car != null)
            {
                allPhotos = new List<string>();

                if (!string.IsNullOrEmpty(car.MainPhotoUrl))
                {
                    allPhotos.Add(car.MainPhotoUrl);
                }

                if (car.PhotoUrls != null && car.PhotoUrls.Count > 0)
                {
                    allPhotos.AddRange(car.PhotoUrls.Where(url => url != car.MainPhotoUrl));
                }
            }
        }
        catch
        {
            Navigation.NavigateTo("/");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadExistingRentals()
    {
        try
        {
            var rentals = await RentalService.GetRentalsByCarIdAsync(CarId);
            existingRentals = rentals
                .Where(r => r.Status != "Cancelled" && r.ReturnDate >= DateTime.Today)
                .ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading rentals: {ex.Message}");
        }
    }

    private bool IsDateDisabled(DateTime date)
    {
        if (date < DateTime.Today)
            return true;

        foreach (var rental in existingRentals)
        {
            if (date >= rental.RentalDate.Date && date <= rental.ReturnDate.Date)
                return true;
        }

        return false;
    }

    private void OnDateRangeChanged(DateRange? dateRange)
    {
        _dateRange = dateRange;

        if (dateRange?.Start != null && dateRange?.End != null && car != null)
        {
            totalDays = (dateRange.End.Value - dateRange.Start.Value).Days + 1;
            totalPrice = car.PricePerDay * totalDays;
        }
        else
        {
            totalDays = 0;
            totalPrice = 0;
        }

        StateHasChanged();
    }

    private async Task ConfirmBooking()
    {
        if (car is null || !car.IsAvailable)
        {
            await ShowErrorDialog("This car is unavailable and cannot be booked.");
            return;
        }

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (!user.Identity?.IsAuthenticated ?? true)
        {
            await OpenLoginDialogAsync();
            return;
        }

        await OpenConfirmationDialogAsync();
        return;
    }

    private async Task OpenLoginDialogAsync()
    {
        var parameters = new DialogParameters<LoginDialog>
        {
            { x => x.ReturnUrl, $"/booking/{CarId}" }
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            CloseButton = false,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<LoginDialog>("Login Required", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            Console.WriteLine("User chose to login");
        }
    }

    private async Task OpenConfirmationDialogAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userName = user.Identity?.Name ?? "Unknown User";

        var parameters = new DialogParameters<ConfirmationDialog>
        {
            { x => x.UserName, userName },
            { x => x.CarBrand, car!.Brand },
            { x => x.CarModel, car!.Model },
            { x => x.StartDate, _dateRange!.Start!.Value },
            { x => x.EndDate, _dateRange!.End!.Value },
            { x => x.TotalPrice, totalPrice },
            { x => x.CarId, CarId },
            { x => x.ReturnUrl, $"/booking/{CarId}" }
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            CloseButton = false,
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<ConfirmationDialog>("Booking Summary", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            try
            {
                authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
                user = authState.User;

                if (!(user.Identity?.IsAuthenticated ?? false))
                {
                    await OpenLoginDialogAsync();
                    return;
                }

                var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                if (string.IsNullOrWhiteSpace(userId))
                {
                    await OpenLoginDialogAsync();
                    return;
                }

                var client = await ClientService.GetClientByUserIdAsync(userId);
                if (client is null)
                {
                    await ShowErrorDialog("Client profile not found for current user.");
                    return;
                }

                var createRentalDto = new CreateRentalDto
                {
                    CarId = CarId,
                    ClientId = client.Id,
                    RentalDate = _dateRange!.Start!.Value,
                    ReturnDate = _dateRange!.End!.Value,
                    IsPaid = true
                };

                var rentalId = await RentalService.CreateRentalAsync(createRentalDto);

                _dateRange = null;
                totalDays = 0;
                totalPrice = 0;

                await LoadExistingRentals();
                await ShowSuccessDialog(rentalId);
            }
            catch (Exception ex)
            {
                await ShowErrorDialog($"Failed to create booking: {ex.Message}");
            }
        }
    }

    private async Task ShowSuccessDialog(int rentalId)
    {
        var parameters = new DialogParameters<SuccessDialog>
        {
            { x => x.RentalId, rentalId },
            { x => x.CarBrand, car!.Brand },
            { x => x.CarModel, car!.Model }
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            CloseButton = false,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<SuccessDialog>("", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is bool viewRentals && viewRentals)
        {
            Navigation.NavigateTo("/my-rentals");
        }
    }

    private async Task ShowErrorDialog(string errorMessage)
    {
        var parameters = new DialogParameters<ErrorDialog>
        {
            { x => x.ErrorMessage, errorMessage }
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            CloseButton = false,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        await DialogService.ShowAsync<ErrorDialog>("", parameters, options);
    }

    private void NextPhoto()
    {
        if (allPhotos.Count > 0)
        {
            currentPhotoIndex = (currentPhotoIndex + 1) % allPhotos.Count;
        }
    }

    private void PreviousPhoto()
    {
        if (allPhotos.Count > 0)
        {
            currentPhotoIndex = currentPhotoIndex == 0 ? allPhotos.Count - 1 : currentPhotoIndex - 1;
        }
    }

    private void Homepage()
    {
        Navigation.NavigateTo("/");
    }
}
