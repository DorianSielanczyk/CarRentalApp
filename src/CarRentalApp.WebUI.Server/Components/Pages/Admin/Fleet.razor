@page "/admin/fleetmanagement"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Worker,Admin")]
@inject IAdminFleetService AdminFleetService
@inject IDialogService DialogService
@inject AuthenticationStateProvider AuthenticationStateProvider

<div class="clients-header">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center">
            <h3 class="mb-0">Fleet Management</h3>
            <a href="/" class="btn back-button">
                <i class="bi bi-arrow-left"></i> Back to homepage
            </a>
        </div>
    </div>
</div>

<div class="filter-header">
    <div class="container">
        <div class="row g-3 align-items-center">
            <div class="col-md-3">
                <input type="text"
                       class="form-control"
                       placeholder="Search by brand or model..."
                       @bind="SearchQuery"
                       @bind:event="oninput" />
            </div>
            <div class="col-md-3">
                <select class="form-select" @bind="SelectedCategoryId">
                    <option value="0">All Categories</option>
                    @foreach (var category in categories)
                    {
                        <option value="@category.CategoryId">@category.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <select class="form-select" @bind="SelectedPriceRange">
                    <option value="all">Any Price</option>
                    <option value="0-50">Under $50/day</option>
                    <option value="50-100">$50 - $100/day</option>
                    <option value="100-150">$100 - $150/day</option>
                    <option value="150+">Over $150/day</option>
                </select>
            </div>
            <div class="col-md-3">
                <button class="btn btn-outline-secondary w-100" @onclick="ClearFilters">
                    <i class="bi bi-x-circle"></i> Clear Filters
                </button>
            </div>
        </div>
    </div>
</div>

<div class="container my-3 fleet-page-content">
    @if (!string.IsNullOrWhiteSpace(feedbackMessage))
    {
        <div class="alert @(feedbackError ? "alert-danger" : "alert-success") mb-3">
            @feedbackMessage
        </div>
    }

    @if (isLoading)
    {
        <div class="report-form-card">
            <p class="mb-0">Loading fleet...</p>
        </div>
    }
    else
    {
        var filteredCars = GetFilteredCars().ToList();
        var totalPages = CalculateTotalPages(filteredCars.Count);
        var pagedCars = PaginatedCars(filteredCars).ToList();

        if (!filteredCars.Any())
        {
            <div class="report-form-card">
                <p class="mb-0">No cars found.</p>
            </div>
        }
        else
        {
            <div class="clients-list">
                @foreach (var car in pagedCars)
                {
                    <div class="report-form-card fleet-card">
                        <div class="fleet-title-row">
                            <div class="client-main-name">@car.Brand @car.Model</div>
                        </div>

                        <div class="fleet-body-row">
                            <div class="fleet-left-side">
                                <div class="fleet-main-photo-wrapper">
                                    @if (!string.IsNullOrWhiteSpace(car.MainPhotoUrl))
                                    {
                                        <img src="@car.MainPhotoUrl" class="fleet-main-photo" alt="@($"{car.Brand} {car.Model}")" />
                                    }
                                    else
                                    {
                                        <div class="fleet-main-photo-placeholder">
                                            <i class="bi bi-car-front-fill"></i>
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="fleet-details-grid">
                                <div><strong>Registration:</strong> @car.RegistrationNumber</div>
                                <div><strong>Year:</strong> @car.YearOfProduction</div>
                                <div><strong>Mileage:</strong> @car.Mileage.ToString("N0") km</div>
                                <div><strong>Price/day:</strong> $@car.PricePerDay.ToString("N2")</div>
                                <div><strong>Category:</strong> @car.CategoryName</div>
                                <div>
                                    <strong>Status:</strong>
                                    <span class="status-pill @GetStatusClass(car.Status)">@car.Status</span>
                                </div>
                            </div>

                            <div class="fleet-actions">
                                <button class="btn btn-outline-secondary btn-sm" @onclick="() => OpenEditDialogAsync(car.CarId)">
                                    Edit data
                                </button>

                                @if (isAdmin || !car.HasReservationHistory)
                                {
                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => OpenDeleteDialogAsync(car.CarId, GetCarName(car))">
                                        Delete car
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="d-flex flex-column align-center">
                <MudPagination ShowFirstButton="true"
                               ShowLastButton="true"
                               Count="@totalPages"
                               Class="mt-4 fleet-pagination"
                               @bind-Selected="currentPage" />
            </div>
        }
    }
</div>

<div class="add-button-bar">
    <div class="container add-button-bar-inner">
        <button class="btn btn-primary add-button" @onclick="OpenAddDialogAsync">
            <i class="bi bi-plus-circle me-1"></i> Add
        </button>
    </div>
</div>

@code {
    private const int PageSize = 6;

    private List<AdminFleetCarListItem> cars = [];
    private List<AdminFleetCategoryItem> categories = [];
    private bool isLoading = true;
    private string feedbackMessage = string.Empty;
    private bool feedbackError;
    private string searchQuery = string.Empty;
    private int selectedCategoryId;
    private string selectedPriceRange = "all";
    private int currentPage = 1;

    private bool canDeleteCars;
    private bool isAdmin;

    private string SearchQuery
    {
        get => searchQuery;
        set
        {
            if (searchQuery == value)
            {
                return;
            }

            searchQuery = value;
            currentPage = 1;
        }
    }

    private int SelectedCategoryId
    {
        get => selectedCategoryId;
        set
        {
            if (selectedCategoryId == value)
            {
                return;
            }

            selectedCategoryId = value;
            currentPage = 1;
        }
    }

    private string SelectedPriceRange
    {
        get => selectedPriceRange;
        set
        {
            if (selectedPriceRange == value)
            {
                return;
            }

            selectedPriceRange = value;
            currentPage = 1;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        isAdmin = authState.User.IsInRole("Admin");

        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        cars = await AdminFleetService.LoadCarsAsync();
        categories = await AdminFleetService.LoadCategoriesAsync();
        isLoading = false;
    }

    private IEnumerable<AdminFleetCarListItem> GetFilteredCars()
    {
        IEnumerable<AdminFleetCarListItem> query = cars;

        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            query = query.Where(car =>
                car.Brand.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                car.Model.Contains(searchQuery, StringComparison.OrdinalIgnoreCase));
        }

        if (selectedCategoryId != 0)
        {
            query = query.Where(car => car.CategoryId == selectedCategoryId);
        }

        query = selectedPriceRange switch
        {
            "0-50" => query.Where(car => car.PricePerDay < 50),
            "50-100" => query.Where(car => car.PricePerDay >= 50 && car.PricePerDay <= 100),
            "100-150" => query.Where(car => car.PricePerDay > 100 && car.PricePerDay <= 150),
            "150+" => query.Where(car => car.PricePerDay > 150),
            _ => query
        };

        return query.OrderBy(car => car.Brand).ThenBy(car => car.Model);
    }

    private IEnumerable<AdminFleetCarListItem> PaginatedCars(IReadOnlyList<AdminFleetCarListItem> filteredCars)
    {
        var totalPages = CalculateTotalPages(filteredCars.Count);
        if (currentPage > totalPages)
        {
            currentPage = totalPages;
        }

        return filteredCars
            .Skip((currentPage - 1) * PageSize)
            .Take(PageSize);
    }

    private static int CalculateTotalPages(int totalItems)
    {
        return Math.Max(1, (int)Math.Ceiling(totalItems / (double)PageSize));
    }

    private void ClearFilters()
    {
        searchQuery = string.Empty;
        selectedCategoryId = 0;
        selectedPriceRange = "all";
        currentPage = 1;
    }

    private async Task OpenAddDialogAsync()
    {
        var model = new AdminFleetCarFormModel
        {
            YearOfProduction = DateTime.Now.Year,
            IsAvailable = true
        };

        var parameters = new DialogParameters
        {
            ["Title"] = "Add car",
            ["SubmitText"] = "Add",
            ["Model"] = model,
            ["Categories"] = categories
        };

        var dialog = await DialogService.ShowAsync<FleetCarUpsertDialog>("Add car", parameters, BuildDialogOptions());
        var result = await dialog.Result;

        if (result.Canceled || result.Data is not AdminFleetCarFormModel payload)
        {
            return;
        }

        var ok = await AdminFleetService.AddCarAsync(payload);
        feedbackError = !ok;
        feedbackMessage = ok ? "Car added successfully." : "Cannot add car. Check registration number and data.";
        await LoadDataAsync();
    }

    private async Task OpenEditDialogAsync(int carId)
    {
        var model = await AdminFleetService.GetCarForEditAsync(carId);
        if (model is null)
        {
            feedbackError = true;
            feedbackMessage = "Car not found.";
            return;
        }

        var parameters = new DialogParameters
        {
            ["Title"] = "Edit car",
            ["SubmitText"] = "Save",
            ["Model"] = model,
            ["Categories"] = categories
        };

        var dialog = await DialogService.ShowAsync<FleetCarUpsertDialog>("Edit car", parameters, BuildDialogOptions());
        var result = await dialog.Result;

        if (result.Canceled || result.Data is not AdminFleetCarFormModel payload)
        {
            return;
        }

        var ok = await AdminFleetService.UpdateCarAsync(payload);
        feedbackError = !ok;
        feedbackMessage = ok ? "Car updated successfully." : "Cannot update car. Check registration number and data.";
        await LoadDataAsync();
    }

    private async Task OpenDeleteDialogAsync(int carId, string carName)
    {
        var parameters = new DialogParameters
        {
            ["CarName"] = carName
        };

        var dialog = await DialogService.ShowAsync<FleetCarDeleteDialog>("Delete car", parameters, BuildDialogOptions());
        var result = await dialog.Result;

        if (result.Canceled)
        {
            return;
        }

        var ok = await AdminFleetService.DeleteCarAsync(carId, isAdmin);
        feedbackError = !ok;
        feedbackMessage = ok
            ? "Car deleted successfully."
            : "Workers can delete only cars without reservation history.";
        await LoadDataAsync();
    }

    private static DialogOptions BuildDialogOptions()
    {
        return new DialogOptions
        {
            CloseOnEscapeKey = true,
            CloseButton = false,
            FullWidth = true,
            MaxWidth = MaxWidth.Small
        };
    }

    private static string GetStatusClass(string status)
    {
        return status switch
        {
            "Available" => "status-available",
            "Rented" => "status-rented",
            _ => "status-unavailable"
        };
    }

    private static string GetCarName(AdminFleetCarListItem car)
    {
        return $"{car.Brand} {car.Model}";
    }
}