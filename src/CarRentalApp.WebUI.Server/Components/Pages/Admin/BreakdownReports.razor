@page "/admin/breakdowns"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Worker,Admin")]
@inject IAdminBreakdownReportsService BreakdownReportsService
@inject AuthenticationStateProvider AuthenticationStateProvider

<div class="breakdown-header">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center">
            <h3 class="mb-0">Breakdown Reports</h3>
            <a href="/" class="btn btn-outline-secondary back-button">
                <i class="bi bi-arrow-left"></i> Back to homepage
            </a>
        </div>
    </div>
</div>

<div class="container my-3">
    <div class="row g-2 mb-3">
        <div class="col-md-4">
            <input class="form-control" placeholder="Registration number" @bind="registrationFilter" />
        </div>
        <div class="col-md-4">
            <select class="form-control" @bind="statusFilter">
                <option value="">Open tickets</option>
                @foreach (var s in Enum.GetValues<BreakdownStatus>())
                {
                    <option value="@s.ToString()">@s</option>
                }
            </select>
        </div>
    </div>

    @foreach (var r in FilteredReports())
    {
        <div class="report-form-card mb-3">
            <div><strong>#@r.Id</strong> | @r.BreakdownType | @r.Status</div>
            <div><strong>Car:</strong> @r.Rental?.Car?.Brand @r.Rental?.Car?.Model (@r.Rental?.Car?.RegistrationNumber)
            </div>
            <div><strong>Client:</strong> @r.Rental?.Client?.FirstName @r.Rental?.Client?.LastName</div>
            <div><strong>Location:</strong> @r.LocationText (@r.Latitude, @r.Longitude)</div>
            <div><strong>Description:</strong> @r.Description</div>

            @if (r.Notes.Any())
            {
                <div class="mt-2">
                    <strong>Internal notes:</strong>
                    @foreach (var n in r.Notes.OrderByDescending(x => x.CreatedAtUtc))
                    {
                        <div class="small text-muted">
                            @n.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm") - @n.Note
                        </div>
                    }
                </div>
            }

            <div class="mt-2">
                <label>Status:</label>
                <select class="form-control" value="@r.Status" @onchange="e => ChangeStatusAsync(r.Id, e.Value?.ToString())">
                    @foreach (var s in Enum.GetValues<BreakdownStatus>())
                    {
                        <option value="@s">@s</option>
                    }
                </select>
            </div>

            <div class="mt-2">
                <input class="form-control" placeholder="Internal note" @bind="noteBuffer[r.Id]" />
                <button class="btn btn-primary mt-2" @onclick="() => AddNoteAsync(r.Id)">Add note</button>
            </div>
        </div>
    }
</div>

@code {
    private List<BreakdownReport> reports = new();
    private string registrationFilter = string.Empty;
    private string statusFilter = string.Empty;
    private readonly Dictionary<int, string> noteBuffer = new();

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        reports = await BreakdownReportsService.LoadReportsAsync();

        foreach (var r in reports)
        {
            if (!noteBuffer.ContainsKey(r.Id))
            {
                noteBuffer[r.Id] = string.Empty;
            }
        }
    }

    private IEnumerable<BreakdownReport> FilteredReports()
    {
        return reports.Where(r =>
            (string.IsNullOrWhiteSpace(registrationFilter) ||
             (r.Rental?.Car?.RegistrationNumber ?? string.Empty).Contains(registrationFilter, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrWhiteSpace(statusFilter)
                ? r.Status != BreakdownStatus.Closed
                : r.Status.ToString() == statusFilter))
            .OrderByDescending(r => r.CreatedAtUtc);
    }

    private async Task ChangeStatusAsync(int reportId, string? status)
    {
        if (Enum.TryParse<BreakdownStatus>(status, out var parsed))
        {
            var updated = await BreakdownReportsService.ChangeStatusAsync(reportId, parsed);
            if (updated)
            {
                await ReloadAsync();
            }
        }
    }

    private async Task AddNoteAsync(int reportId)
    {
        if (!noteBuffer.TryGetValue(reportId, out var note) || string.IsNullOrWhiteSpace(note))
        {
            return;
        }

        var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userName = auth.User.Identity?.Name ?? "Unknown";

        var added = await BreakdownReportsService.AddNoteAsync(reportId, note, userName);
        if (added)
        {
            noteBuffer[reportId] = string.Empty;
            await ReloadAsync();
        }
    }
}