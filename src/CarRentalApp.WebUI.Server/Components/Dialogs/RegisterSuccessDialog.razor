<MudDialog Style="backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); background-color: rgba(41, 37, 33, 0.95); border-radius: 12px; overflow: hidden; box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);">
    <TitleContent>
        <div style="background: #1C1917; padding: 1rem; margin: -24px -24px 0 -24px; border-bottom: 1px solid rgba(255, 255, 255, 0.1);">
            <MudText Typo="Typo.h6" Style="color: white; font-weight: 600;">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Class="me-2" Style="color: white;" />
                Registration successful
            </MudText>
        </div>
    </TitleContent>

    <DialogContent>
        <div class="text-center py-4">
            <MudIcon Icon="@Icons.Material.Filled.PersonAddAlt1"
                     Size="Size.Large"
                     Style="font-size: 4rem; color: white;" />
            <MudText Typo="Typo.body1" Class="mt-3" Style="color: rgba(255, 255, 255, 0.9);">
                Your account has been created.
            </MudText>
            @if (!string.IsNullOrWhiteSpace(Email))
            {
                <MudText Typo="Typo.body2" Class="mt-1" Style="color: rgba(255, 255, 255, 0.7);">
                    @Email
                </MudText>
            }
        </div>
    </DialogContent>

    <DialogActions>
        <MudButton Color="Color.Default"
                   Variant="Variant.Text"
                   OnClick="StayHere"
                   Style="color: #dc3545; text-transform: uppercase; font-weight: 500;">
            Stay here
        </MudButton>
        <MudButton Color="Color.Success"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Login"
                   OnClick="GoToLogin"
                   Style="background-color: #217418; color: white; text-transform: uppercase; font-weight: 500;">
            Go to login
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public string Email { get; set; } = string.Empty;

    private void GoToLogin() => MudDialog.Close(DialogResult.Ok(true));

    private void StayHere() => MudDialog.Cancel();
}