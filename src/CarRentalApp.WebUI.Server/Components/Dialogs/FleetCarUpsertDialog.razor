@using CarRentalApp.Domain.Interfaces
@using MudBlazor

<MudDialog Style="backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); background-color: rgba(41, 37, 33, 0.95); border-radius: 12px; overflow: hidden; box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);">
    <TitleContent>
        <div style="background: #1C1917; padding: 1rem; margin: -24px -24px 0 -24px; border-bottom: 1px solid rgba(255, 255, 255, 0.1);">
            <MudText Typo="Typo.h6" Style="color: white; font-weight: 600;">
                <MudIcon Icon="@Icons.Material.Filled.DirectionsCar" Class="me-2" />
                @Title
            </MudText>
        </div>
    </TitleContent>

    <DialogContent>
        @if (!string.IsNullOrWhiteSpace(validationError))
        {
            <div class="alert alert-danger py-2 mt-3">@validationError</div>
        }

        <div class="mb-2 mt-3">
            <label class="form-label" style="color: rgba(255, 255, 255, 0.85);">Brand</label>
            <input class="form-control" @bind="editModel.Brand" />
        </div>

        <div class="mb-2">
            <label class="form-label" style="color: rgba(255, 255, 255, 0.85);">Model</label>
            <input class="form-control" @bind="editModel.Model" />
        </div>

        <div class="mb-2">
            <label class="form-label" style="color: rgba(255, 255, 255, 0.85);">Registration number</label>
            <input class="form-control" @bind="editModel.RegistrationNumber" />
        </div>

        <div class="mb-2">
            <label class="form-label" style="color: rgba(255, 255, 255, 0.85);">Main photo URL/path</label>
            <input class="form-control" @bind="editModel.MainPhotoUrl" placeholder="/images/cars/example.jpg" />
        </div>

        <div class="mb-2">
            <label class="form-label" style="color: rgba(255, 255, 255, 0.85);">Additional photo URL(s)</label>
            <textarea class="form-control"
                      rows="2"
                      @bind="editModel.AdditionalPhotoUrls"
                      placeholder="/images/cars/example-2.jpg, /images/cars/example-3.jpg"></textarea>
            <small style="color: rgba(255, 255, 255, 0.6);">Use comma, semicolon or new line to add multiple photos.</small>
        </div>

        @if (editModel.ExistingPhotos.Any())
        {
            <div class="mb-2">
                <label class="form-label" style="color: rgba(255, 255, 255, 0.85);">Existing photos</label>

                <div class="d-flex flex-column gap-2">
                    @foreach (var photo in editModel.ExistingPhotos)
                    {
                        var markedForDelete = IsPhotoMarkedForDelete(photo.Id);

                        <div class="d-flex justify-content-between align-items-center p-2 rounded"
                             style="background-color: rgba(255, 255, 255, 0.06); border: 1px solid rgba(255, 255, 255, 0.12); @(markedForDelete ? "opacity: 0.55;" : string.Empty)">
                            <div class="d-flex align-items-center gap-2" style="min-width: 0;">
                                <img src="@photo.PhotoUrl"
                                     alt="Car photo"
                                     style="width: 48px; height: 48px; object-fit: cover; border-radius: 6px; border: 1px solid rgba(255,255,255,0.2);" />

                                <div style="min-width: 0;">
                                    <div style="color: rgba(255, 255, 255, 0.85); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 320px;">
                                        @photo.PhotoUrl
                                    </div>
                                    @if (photo.IsMain)
                                    {
                                        <small style="color: #9ad29a;">Main photo</small>
                                    }
                                </div>
                            </div>

                            <button type="button"
                                    class="btn btn-sm photo-delete-btn @(markedForDelete ? "btn-outline-warning" : "btn-outline-danger")"
                                    @onclick="() => TogglePhotoDelete(photo.Id)">
                                @(markedForDelete ? "Undo" : "Delete")
                            </button>
                        </div>
                    }
                </div>
            </div>
        }

        <div class="row g-2">
            <div class="col-6">
                <label class="form-label" style="color: rgba(255, 255, 255, 0.85);">Year</label>
                <input class="form-control" type="number" @bind="editModel.YearOfProduction" />
            </div>
            <div class="col-6">
                <label class="form-label" style="color: rgba(255, 255, 255, 0.85);">Mileage</label>
                <input class="form-control" type="number" @bind="editModel.Mileage" />
            </div>
        </div>

        <div class="row g-2 mt-1">
            <div class="col-6">
                <label class="form-label" style="color: rgba(255, 255, 255, 0.85);">Price/day</label>
                <input class="form-control" type="number" step="0.01" @bind="editModel.PricePerDay" />
            </div>
            <div class="col-6">
                <label class="form-label" style="color: rgba(255, 255, 255, 0.85);">Category</label>
                <select class="form-select" @bind="editModel.CategoryId">
                    <option value="0">Select category</option>
                    @foreach (var category in Categories)
                    {
                        <option value="@category.CategoryId">@category.Name</option>
                    }
                </select>
            </div>
        </div>

        <div class="form-check mt-3">
            <input id="available-check" class="form-check-input" type="checkbox" @bind="editModel.IsAvailable" />
            <label class="form-check-label" for="available-check" style="color: rgba(255, 255, 255, 0.85);">Available</label>
        </div>
    </DialogContent>

    <DialogActions>
        <MudButton Color="Color.Error"
                   Variant="Variant.Text"
                   OnClick="Cancel"
                   Style="color: #dc3545; text-transform: uppercase; font-weight: 500;">
            Cancel
        </MudButton>
        <MudButton Color="Color.Success"
                   Variant="Variant.Filled"
                   OnClick="Submit"
                   Style="background-color: #217418; color: white; text-transform: uppercase; font-weight: 500;">
            @SubmitText
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
    .photo-delete-btn:focus,
    .photo-delete-btn:active,
    .photo-delete-btn:focus-visible,
    .photo-delete-btn:active:focus {
        outline: none !important;
        box-shadow: none !important;
    }
</style>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public string Title { get; set; } = "Car";

    [Parameter]
    public string SubmitText { get; set; } = "Save";

    [Parameter]
    public AdminFleetCarFormModel Model { get; set; } = new();

    [Parameter]
    public List<AdminFleetCategoryItem> Categories { get; set; } = [];

    private AdminFleetCarFormModel editModel = new();
    private string validationError = string.Empty;

    protected override void OnParametersSet()
    {
        editModel = new AdminFleetCarFormModel
        {
            Id = Model.Id,
            Brand = Model.Brand,
            Model = Model.Model,
            RegistrationNumber = Model.RegistrationNumber,
            YearOfProduction = Model.YearOfProduction,
            PricePerDay = Model.PricePerDay,
            Mileage = Model.Mileage,
            IsAvailable = Model.IsAvailable,
            CategoryId = Model.CategoryId,
            MainPhotoUrl = Model.MainPhotoUrl,
            AdditionalPhotoUrls = string.Empty,
            ExistingPhotos = Model.ExistingPhotos
                .Select(p => new AdminFleetCarPhotoItem
                {
                    Id = p.Id,
                    PhotoUrl = p.PhotoUrl,
                    IsMain = p.IsMain
                })
                .ToList(),
            DeletedPhotoIds = []
        };
    }

    private bool IsPhotoMarkedForDelete(int photoId)
    {
        return editModel.DeletedPhotoIds.Contains(photoId);
    }

    private void TogglePhotoDelete(int photoId)
    {
        if (editModel.DeletedPhotoIds.Contains(photoId))
        {
            editModel.DeletedPhotoIds.Remove(photoId);
        }
        else
        {
            editModel.DeletedPhotoIds.Add(photoId);
        }
    }

    private void Submit()
    {
        validationError = string.Empty;

        if (string.IsNullOrWhiteSpace(editModel.Brand) ||
            string.IsNullOrWhiteSpace(editModel.Model) ||
            string.IsNullOrWhiteSpace(editModel.RegistrationNumber) ||
            editModel.CategoryId <= 0 ||
            editModel.YearOfProduction < 1950 ||
            editModel.PricePerDay <= 0 ||
            editModel.Mileage < 0)
        {
            validationError = "Please provide valid data in all required fields.";
            return;
        }

        MudDialog.Close(DialogResult.Ok(editModel));
    }

    private void Cancel() => MudDialog.Cancel();
}