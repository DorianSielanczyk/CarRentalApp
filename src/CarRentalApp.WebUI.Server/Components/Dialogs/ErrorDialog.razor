@using MudBlazor

<MudDialog Style="backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); background-color: rgba(41, 37, 33, 0.95); border-radius: 12px; overflow: hidden; box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);">
    <TitleContent>
        <div style="background: #1C1917; padding: 1rem; margin: -24px -24px 0 -24px; border-bottom: 1px solid rgba(255, 255, 255, 0.1);">
            <MudText Typo="Typo.h6" Style="color: white; font-weight: 600;">
                <MudIcon Icon="@Icons.Material.Filled.Error" Class="me-2" Style="color: white;" />
                Booking Error
            </MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <div class="text-center py-4">
            <MudIcon Icon="@Icons.Material.Filled.Error"
                     Size="Size.Large"
                     Style="font-size: 4rem; color: white" />
            <MudText Typo="Typo.body1" Class="mt-3" Style="color: rgba(255, 255, 255, 0.9);">
                @ErrorMessage
            </MudText>
        </div>
    </DialogContent>
    <DialogActions>
            <MudButton Color="Color.Primary"
                       Variant="Variant.Filled"
                       OnClick="Close"
                       Style="background-color: #217418; color: white; text-transform: uppercase; font-weight: 500;">
                OK
            </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public string ErrorMessage { get; set; } = string.Empty;

    private void Close() => MudDialog.Close();
}