@using MudBlazor

<MudDialog Class="employee-status-dialog" Style="backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); background-color: rgba(41, 37, 33, 0.95); border-radius: 12px; overflow: hidden; box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);">
    <TitleContent>
        <div style="background: #1C1917; padding: 1rem; margin: -24px -24px 0 -24px; border-bottom: 1px solid rgba(255, 255, 255, 0.1);">
            <MudText Typo="Typo.h6" Style="color: white; font-weight: 600;">
                <MudIcon Icon="@Icons.Material.Filled.ManageAccounts" Class="me-2" />
                Change employee status
            </MudText>
        </div>
    </TitleContent>

    <DialogContent>
        <MudText Typo="Typo.body2" Class="mt-3" Style="color: rgba(255, 255, 255, 0.85);">
            <strong>@EmployeeName</strong>
        </MudText>

        <div class="mt-3">
            <label class="form-label" style="color: rgba(255, 255, 255, 0.85);">Status</label>
            <select class="form-select" @bind="selectedStatus">
                <option value="Employee">User</option>
                <option value="Worker">Worker</option>
                <option value="Admin">Admin</option>
            </select>
        </div>
    </DialogContent>

    <DialogActions>
        <MudButton Color="Color.Error"
                   Variant="Variant.Text"
                   OnClick="Cancel"
                   Class="dialog-action-btn"
                   Style="color: #dc3545; text-transform: uppercase; font-weight: 500;">
            Cancel
        </MudButton>
        <MudButton Color="Color.Success"
                   Variant="Variant.Filled"
                   OnClick="Save"
                   Class="dialog-action-btn"
                   Style="background-color: #217418; color: white; text-transform: uppercase; font-weight: 500;">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
    .employee-status-dialog .dialog-action-btn:focus,
    .employee-status-dialog .dialog-action-btn:active,
    .employee-status-dialog .dialog-action-btn:focus-visible,
    .employee-status-dialog .form-select:focus,
    .employee-status-dialog .form-select:active,
    .employee-status-dialog .form-select:focus-visible {
        outline: none !important;
        box-shadow: none !important;
    }
</style>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public string EmployeeName { get; set; } = string.Empty;

    [Parameter]
    public string CurrentStatus { get; set; } = "Employee";

    private string selectedStatus = "Employee";

    protected override void OnParametersSet()
    {
        selectedStatus = string.IsNullOrWhiteSpace(CurrentStatus) ? "Employee" : CurrentStatus;
    }

    private void Save() => MudDialog.Close(DialogResult.Ok(selectedStatus));

    private void Cancel() => MudDialog.Cancel();
}
