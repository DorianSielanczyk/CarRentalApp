{
  // Database mode:
  // True - Use In-Memory database with mock data (for demo purposes)
  // False - Use Azure SQL Database (requires valid connection string in User Secrets)
  "UseMockDatabase": true,

  // Add connection string for Azure SQL Database
  "ConnectionStrings": {
    "DefaultConnection": "Server=tcp:carrentalapp.database.windows.net,1433;Initial Catalog=CarRentalAppDataBase;Persist Security Info=False;User ID=sqladmin;Password=<HIDDEN_IN_USER_SECRETS>;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}

